# ========================
# HubFarm API — Environment
# ========================

# App
NODE_ENV=development
PORT=3333
API_URL=http://localhost:3333

# Database (PostgreSQL + PostGIS)
DATABASE_URL="postgresql://hubfarm:hubfarm123@localhost:5432/hubfarm_db?schema=public"

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# Satellite — Element84 Earth Search (GRATUITO, sem chave)
STAC_API_URL=https://earth-search.aws.element84.com/v1

# Google Maps (para geocoding e validação de coordenadas)
# Cadastre em: https://console.cloud.google.com/
GOOGLE_MAPS_API_KEY=your_google_maps_key

# Copernicus Data Space (GRATUITO com cadastro)
# Cadastre em: https://dataspace.copernicus.eu/
COPERNICUS_CLIENT_ID=
COPERNICUS_CLIENT_SECRET=

# Email (Resend — gratuito até 3k/mês)
# Cadastre em: https://resend.com/
RESEND_API_KEY=

# Rate Limit
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60000
